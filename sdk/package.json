{
  "name": "@curved/x402",
  "version": "0.4.1",
  "description": "x402 payments on Solana with no facilitator, no account and no per-transaction fee. The payer signs 143 bytes offline; anyone, including the payee, can settle them.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "tsx test/e2e.ts",
    "test:wall": "tsx test/wall-e2e.ts",
    "test:wallet": "tsx test/wallet.ts",
    "test:suite": "tsx test/suite.ts",
    "test:concurrent": "tsx test/concurrent.ts",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./zero": {
      "types": "./zero/client.d.mts",
      "import": "./zero/client.mjs"
    },
    "./wallet": {
      "types": "./zero/wallet.d.mts",
      "import": "./zero/wallet.mjs"
    }
  },
  "bin": {
    "curved": "dist/cli.js"
  },
  "files": [
    "dist",
    "zero/client.mjs",
    "zero/client.d.mts",
    "zero/wallet.mjs",
    "zero/wallet.d.mts",
    "README.md"
  ],
  "keywords": [
    "x402",
    "solana",
    "payments",
    "agent",
    "http-402",
    "micropayments",
    "usdc",
    "anchor",
    "web3",
    "settlement",
    "escrow"
  ],
  "author": {
    "name": "CURVED core",
    "url": "https://github.com/Curved-labs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Curved-labs/x402.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/Curved-labs/x402#readme",
  "bugs": {
    "url": "https://github.com/Curved-labs/x402/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "prettier": "^3.4.0"
  }
}
